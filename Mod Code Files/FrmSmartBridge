Private Sub AddMaterial(ByVal nameText As String, ByVal EVal As Double, ByVal FyVal As Double, ByVal densityVal As Double)

    If Len(Trim$(nameText)) = 0 Then Exit Sub
    If EVal <= 0# Or FyVal <= 0# Or densityVal <= 0# Then Exit Sub

    matCount = matCount + 1

    If matCount = 1 Then
        ReDim matName(1 To 1)
        ReDim matE(1 To 1)
        ReDim matFy(1 To 1)
        ReDim matDensity(1 To 1)
    Else
        ReDim Preserve matName(1 To matCount)
        ReDim Preserve matE(1 To matCount)
        ReDim Preserve matFy(1 To matCount)
        ReDim Preserve matDensity(1 To matCount)
    End If

    matName(matCount) = nameText
    matE(matCount) = EVal
    matFy(matCount) = FyVal
    matDensity(matCount) = densityVal

End Sub

Private Sub AddFinish(ByVal nameText As String, ByVal multVal As Double, ByVal rVal As Long, ByVal gVal As Long, ByVal bVal As Long)

    If Len(Trim$(nameText)) = 0 Then Exit Sub
    If multVal <= 0# Then multVal = 1#

    finCount = finCount + 1

    If finCount = 1 Then
        ReDim finName(1 To 1)
        ReDim finMult(1 To 1)
        ReDim finR(1 To 1)
        ReDim finG(1 To 1)
        ReDim finB(1 To 1)
    Else
        ReDim Preserve finName(1 To finCount)
        ReDim Preserve finMult(1 To finCount)
        ReDim Preserve finR(1 To finCount)
        ReDim Preserve finG(1 To finCount)
        ReDim Preserve finB(1 To finCount)
    End If

    finName(finCount) = nameText
    finMult(finCount) = multVal
    finR(finCount) = ClampByte(rVal)
    finG(finCount) = ClampByte(gVal)
    finB(finCount) = ClampByte(bVal)

End Sub

