Private Function CalculateAndDisplay(ByVal quiet As Boolean) As Boolean

    Dim inp As BridgeInputs
    Dim temp As SectionCalc
    Dim result As SectionCalc
    Dim lay As LayoutCalc
    Dim errMsg As String
    Dim i As Long
    Dim bestIdx As Long
    Dim failIdx As Long
    Dim bestScore As Double
    Dim failUtil As Double
    Dim candidatePass As Boolean
    Dim score As Double

    CalculateAndDisplay = False
    mSound = False
    cmdCreate.Enabled = False

    If secCount <= 0 Then
        SetStatus "NO SECTION DATA", vbRed
        txtValidationReport.Text = "No section database is loaded."
        Exit Function
    End If

    If Not TryReadInputs(inp, errMsg) Then
        SetStatus "INPUT ERROR", vbRed
        txtValidationReport.Text = errMsg
        Exit Function
    End If

    bestIdx = 0
    failIdx = 0
    bestScore = 1E+99
    failUtil = 1E+99

    For i = 1 To secCount

        CalcSection i, inp, temp

        candidatePass = False

        If temp.uB <= 1# Then
            If temp.uS <= 1# Then
                If temp.uVM <= 1# Then
                    If temp.uD <= 1# Then
                        If temp.uF <= 1# Then
                            candidatePass = True
                        End If
                    End If
                End If
            End If
        End If

        If temp.uMax < failUtil Then
            failUtil = temp.uMax
            failIdx = i
        End If

        If candidatePass Then
            If chkLightest.Value = True Then
                score = secMass(i)
            Else
                score = secCost(i)
            End If

            If score < bestScore Then
                bestScore = score
                bestIdx = i
            End If
        End If

    Next i

    If bestIdx > 0 Then
        mSound = True
        mBestIdx = bestIdx
    Else
        mSound = False
        mBestIdx = failIdx
    End If

    If mBestIdx <= 0 Then
        SetStatus "NO VALID SECTION", vbRed
        txtValidationReport.Text = "No usable beam section could be selected." & vbCrLf & vbCrLf & _
                                   "This usually means the span/load is too high for the sections currently loaded." & vbCrLf & _
                                   "Press Load workbook and confirm your Sections sheet is being read."
        Exit Function
    End If

    CalcSection mBestIdx, inp, result
    EstimateLayoutAndCost mBestIdx, inp, lay

    txtValidationReport.Text = FormatValidationReport(mSound, mBestIdx, inp, result, lay)

    mChecked = True
    mSpanM = inp.SpanM
    mBridgeWidthM = inp.BridgeWidthM
    mSelectedSection = secName(mBestIdx)
    mCrossMembers = lay.nCross
    mPosts = lay.nPosts
    mDeckPanels = lay.nPanels
    mActualCrossSpacingM = lay.actualCrossSpacing
    mTotalCost = lay.totalCost
    mTotalMass = lay.totalMass
    mFinishR = inp.finishR
    mFinishG = inp.finishG
    mFinishB = inp.finishB
    mFinishMultiplier = inp.finishMult

    If mSound Then
        SetStatus "PASS - STRUCTURALLY SOUND", RGB(0, 128, 0)
        cmdCreate.Enabled = True
        CalculateAndDisplay = True
    Else
        SetStatus "FAIL - CHANGE DESIGN", vbRed
        cmdCreate.Enabled = False
        CalculateAndDisplay = False
    End If

End Function

Private Function TryReadInputs(ByRef inp As BridgeInputs, ByRef errMsg As String) As Boolean

    TryReadInputs = False

    If Len(Trim$(txtProjectName.Text)) = 0 Then
        errMsg = "Project name cannot be blank."
        GoTo BadInput
    End If

    If Len(Trim$(txtSavePath.Text)) = 0 Then
        errMsg = "Save folder cannot be blank."
        GoTo BadInput
    End If

    If Not TryPositiveDouble(txtSpan.Text, inp.SpanM) Then
        errMsg = "Bridge span must be a positive non-zero number."
        GoTo BadInput
    End If

    If inp.SpanM <= 0# Then
        errMsg = "Bridge span must be greater than zero."
        GoTo BadInput
    End If

    If inp.SpanM > 60# Then
        errMsg = "Bridge span is very large for this macro. Use 60 m or less, or add larger sections to the workbook."
        GoTo BadInput
    End If

    If Len(cboWidth.Value) = 0 Then
        errMsg = "Select a preferred bridge width."
        GoTo BadInput
    End If

    inp.BridgeWidthM = Val(cboWidth.Value)

    If inp.BridgeWidthM <= 0# Then
        errMsg = "Bridge width must be positive."
        GoTo BadInput
    End If

    If Len(cboLoadClass.Value) = 0 Then
        errMsg = "Select a live load class."
        GoTo BadInput
    End If

    inp.qLive = Val(cboLoadClass.Value)

    If inp.qLive <= 0# Then
        errMsg = "Live load class is invalid."
        GoTo BadInput
    End If

    If Not GetMaterial(cboMaterial.Value, inp.YoungsE, inp.Fy, inp.density) Then
        errMsg = "Select a valid material from the Materials worksheet."
        GoTo BadInput
    End If

    If Not GetDeck(cboDeck.Value, inp.qDeck, inp.deckCost) Then
        errMsg = "Select a valid deck type."
        GoTo BadInput
    End If

    If Not GetFinish(cboFinish.Value, inp.finishMult, inp.finishR, inp.finishG, inp.finishB) Then
        errMsg = "Select a valid finish from the Finishes worksheet."
        GoTo BadInput
    End If

    If Not TryPositiveDouble(txtSafetyFactor.Text, inp.FoS) Then
        errMsg = "Safety factor must be a positive number."
        GoTo BadInput
    End If

    If inp.FoS < 1# Then
        errMsg = "Safety factor must be 1.00 or greater."
        GoTo BadInput
    End If

    If Not TryPositiveDouble(txtDeflectionRatio.Text, inp.deflRatio) Then
        errMsg = "Deflection ratio must be a positive number, e.g. 360."
        GoTo BadInput
    End If

    If inp.deflRatio < 100# Then
        errMsg = "Deflection ratio must be 100 or greater."
        GoTo BadInput
    End If

    If Not TryPositiveDouble(txtCrossSpacing.Text, inp.crossSpacingMM) Then
        errMsg = "Cross member spacing must be positive."
        GoTo BadInput
    End If

    If Not TryPositiveDouble(txtPostSpacing.Text, inp.postSpacingMM) Then
        errMsg = "Post spacing must be positive."
        GoTo BadInput
    End If

    If Not TryPositiveDouble(txtRailHeight.Text, inp.railHeightMM) Then
        errMsg = "Guard rail height must be positive."
        GoTo BadInput
    End If

    If Not TryPositiveDouble(txtPanelLength.Text, inp.panelLengthMM) Then
        errMsg = "Deck panel length must be positive."
        GoTo BadInput
    End If

    If chkDynamic.Value = True Then
        inp.dynFactor = 1.15
    Else
        inp.dynFactor = 1#
    End If

    TryReadInputs = True
    Exit Function

BadInput:

    errMsg = "Input validation failed:" & vbCrLf & " - " & errMsg

End Function

Private Sub CalcSection(ByVal idx As Long, ByRef inp As BridgeInputs, ByRef r As SectionCalc)

    Dim qRailAndCross_kN_m As Double
    Dim qTotalNoBeam_N_m As Double
    Dim allowBending As Double
    Dim allowShear As Double
    Dim deltaLimit As Double
    Dim massLine As Double

    If idx <= 0 Or idx > secCount Then
        r.uMax = 999#
        Exit Sub
    End If

    If secArea(idx) <= 0# Or secIxx(idx) <= 0# Or secZxx(idx) <= 0# Then
        r.uMax = 999#
        r.uB = 999#
        r.uS = 999#
        r.uVM = 999#
        r.uD = 999#
        r.uF = 999#
        Exit Sub
    End If

    qRailAndCross_kN_m = CROSS_MEMBER_ALLOWANCE_KN_M
    qRailAndCross_kN_m = qRailAndCross_kN_m + BASE_RAIL_ALLOWANCE_KN_M * (inp.railHeightMM / 1100#)

    qTotalNoBeam_N_m = ((inp.qLive * inp.dynFactor) + inp.qDeck) * inp.BridgeWidthM
    qTotalNoBeam_N_m = qTotalNoBeam_N_m + qRailAndCross_kN_m
    qTotalNoBeam_N_m = qTotalNoBeam_N_m * 1000#

    r.qBeam = (qTotalNoBeam_N_m / 2#) + (secMass(idx) * G)

    r.M = r.qBeam * (inp.SpanM ^ 2) / 8#
    r.V = r.qBeam * inp.SpanM / 2#

    r.sigma = r.M / secZxx(idx)
    r.tau = 1.5 * r.V / secArea(idx)
    r.vm = Sqr((r.sigma ^ 2) + (3# * (r.tau ^ 2)))

    r.delta = (5# * r.qBeam * (inp.SpanM ^ 4)) / (384# * inp.YoungsE * secIxx(idx))

    massLine = r.qBeam / G

    If massLine > 0# Then
        r.f1 = (PI / 2#) * Sqr((inp.YoungsE * secIxx(idx)) / (massLine * (inp.SpanM ^ 4)))
    Else
        r.f1 = 0#
    End If

    allowBending = inp.Fy / inp.FoS
    allowShear = (inp.Fy / Sqr(3#)) / inp.FoS
    deltaLimit = inp.SpanM / inp.deflRatio

    r.uB = r.sigma / allowBending
    r.uS = r.tau / allowShear
    r.uVM = r.vm / allowBending
    r.uD = r.delta / deltaLimit

    If r.f1 <= 0# Then
        r.uF = 999#
    Else
        r.uF = MIN_FREQ_HZ / r.f1
    End If

    r.uMax = Max6(r.uB, r.uS, r.uVM, r.uD, r.uF, 0#)

End Sub

Private Sub EstimateLayoutAndCost(ByVal idx As Long, ByRef inp As BridgeInputs, ByRef lay As LayoutCalc)

    Dim crossSpacingM As Double
    Dim postSpacingM As Double
    Dim panelLengthM As Double
    Dim nPostsPerSide As Long
    Dim mainBeamCost As Double
    Dim crossCost As Double
    Dim deckCostTotal As Double
    Dim postCost As Double
    Dim railCost As Double
    Dim steelworkCost As Double
    Dim mainBeamMass As Double
    Dim crossMass As Double
    Dim deckMass As Double
    Dim postMass As Double
    Dim railMass As Double

    crossSpacingM = inp.crossSpacingMM / 1000#
    postSpacingM = inp.postSpacingMM / 1000#
    panelLengthM = inp.panelLengthMM / 1000#

    lay.nCross = CeilingLong(inp.SpanM / crossSpacingM) + 1
    If lay.nCross < 2 Then lay.nCross = 2
    lay.actualCrossSpacing = inp.SpanM / (lay.nCross - 1)

    nPostsPerSide = CeilingLong(inp.SpanM / postSpacingM) + 1
    If nPostsPerSide < 2 Then nPostsPerSide = 2
    lay.nPosts = nPostsPerSide * 2

    lay.nPanels = CeilingLong(inp.SpanM / panelLengthM)
    If lay.nPanels < 1 Then lay.nPanels = 1

    mainBeamCost = 2# * inp.SpanM * secCost(idx)
    crossCost = lay.nCross * inp.BridgeWidthM * CROSS_MEMBER_COST_GBP_M
    deckCostTotal = inp.SpanM * inp.BridgeWidthM * inp.deckCost
    postCost = lay.nPosts * POST_COST_GBP_EA
    railCost = (4# * inp.SpanM * RAIL_COST_GBP_M) + (2# * inp.SpanM * KICKPLATE_COST_GBP_M)

    steelworkCost = mainBeamCost + crossCost + postCost + railCost
    lay.totalCost = (steelworkCost * inp.finishMult) + deckCostTotal

    mainBeamMass = 2# * inp.SpanM * secMass(idx)
    crossMass = lay.nCross * inp.BridgeWidthM * CROSS_MEMBER_MASS_KG_M
    deckMass = (inp.qDeck * 1000# / G) * inp.SpanM * inp.BridgeWidthM
    postMass = lay.nPosts * POST_MASS_KG_EA
    railMass = 4# * inp.SpanM * RAIL_MASS_KG_M

    lay.totalMass = mainBeamMass + crossMass + deckMass + postMass + railMass

End Sub

Private Function FormatValidationReport(ByVal resultPass As Boolean, ByVal idx As Long, ByRef inp As BridgeInputs, ByRef r As SectionCalc, ByRef lay As LayoutCalc) As String

    Dim s As String
    Dim passText As String
    Dim qRailAndCross As Double

    If resultPass Then
        passText = "PASS - STRUCTURALLY SOUND"
    Else
        passText = "FAIL - CHANGE INPUTS OR ADD LARGER SECTION"
    End If

    qRailAndCross = CROSS_MEMBER_ALLOWANCE_KN_M
    qRailAndCross = qRailAndCross + BASE_RAIL_ALLOWANCE_KN_M * (inp.railHeightMM / 1100#)

    s = ""
    s = s & "STRUCTURAL VALIDATION RESULT: " & passText & vbCrLf
    s = s & String$(64, "-") & vbCrLf
    s = s & "INPUTS" & vbCrLf
    s = s & "Project: " & txtProjectName.Text & vbCrLf
    s = s & "Span L: " & Format$(inp.SpanM, "0.00") & " m" & vbCrLf
    s = s & "Bridge width: " & Format$(inp.BridgeWidthM, "0.00") & " m" & vbCrLf
    s = s & "Material: " & cboMaterial.Value & vbCrLf
    s = s & "Finish: " & cboFinish.Value & "  RGB(" & inp.finishR & "," & inp.finishG & "," & inp.finishB & ")" & vbCrLf
    s = s & "Live load: " & Format$(inp.qLive, "0.00") & " kN/m2" & vbCrLf
    s = s & "Dynamic factor: " & Format$(inp.dynFactor, "0.00") & vbCrLf
    s = s & "Deck load: " & Format$(inp.qDeck, "0.00") & " kN/m2" & vbCrLf
    s = s & "Rail/cross allowance: " & Format$(qRailAndCross, "0.00") & " kN/m" & vbCrLf
    s = s & "Safety factor: " & Format$(inp.FoS, "0.00") & vbCrLf
    s = s & "Deflection limit: L/" & Format$(inp.deflRatio, "0") & vbCrLf & vbCrLf

    s = s & "SELECTED PREFERRED SECTION" & vbCrLf
    s = s & "Beam: " & secName(idx) & vbCrLf
    s = s & "Depth: " & Format$(secDepth(idx) * 1000#, "0") & " mm" & vbCrLf
    s = s & "Width: " & Format$(secWidth(idx) * 1000#, "0") & " mm" & vbCrLf
    s = s & "Area: " & Format$(secArea(idx) * 1000000#, "0") & " mm2" & vbCrLf
    s = s & "Ixx: " & Format$(secIxx(idx) * 1000000000000#, "0") & " mm4" & vbCrLf
    s = s & "Zxx: " & Format$(secZxx(idx) * 1000000000#, "0") & " mm3" & vbCrLf
    s = s & "Mass: " & Format$(secMass(idx), "0.0") & " kg/m" & vbCrLf & vbCrLf

    s = s & "STRUCTURAL RESULTS PER MAIN BEAM" & vbCrLf
    s = s & "Line load w: " & Format$(r.qBeam / 1000#, "0.00") & " kN/m" & vbCrLf
    s = s & "Max moment M: " & Format$(r.M / 1000#, "0.00") & " kNm" & vbCrLf
    s = s & "Max shear V: " & Format$(r.V / 1000#, "0.00") & " kN" & vbCrLf
    s = s & "Bending stress: " & Format$(r.sigma / 1000000#, "0.0") & " MPa" & vbCrLf
    s = s & "Shear stress: " & Format$(r.tau / 1000000#, "0.0") & " MPa" & vbCrLf
    s = s & "Von Mises stress: " & Format$(r.vm / 1000000#, "0.0") & " MPa" & vbCrLf
    s = s & "Deflection: " & Format$(r.delta * 1000#, "0.00") & " mm" & vbCrLf
    s = s & "Deflection limit: " & Format$((inp.SpanM / inp.deflRatio) * 1000#, "0.00") & " mm" & vbCrLf
    s = s & "Frequency f1: " & Format$(r.f1, "0.00") & " Hz" & vbCrLf & vbCrLf

    s = s & "UTILISATION CHECKS" & vbCrLf
    s = s & "Bending utilisation: " & Format$(r.uB, "0.00") & vbCrLf
    s = s & "Shear utilisation: " & Format$(r.uS, "0.00") & vbCrLf
    s = s & "Von Mises utilisation: " & Format$(r.uVM, "0.00") & vbCrLf
    s = s & "Deflection utilisation: " & Format$(r.uD, "0.00") & vbCrLf
    s = s & "Frequency utilisation: " & Format$(r.uF, "0.00") & vbCrLf
    s = s & "Overall utilisation: " & Format$(r.uMax, "0.00") & "   target <= 1.00" & vbCrLf & vbCrLf

    s = s & "AUTOMATIC LAYOUT OUTPUT" & vbCrLf
    s = s & "Cross members: " & lay.nCross & vbCrLf
    s = s & "Actual cross spacing: " & Format$(lay.actualCrossSpacing * 1000#, "0") & " mm" & vbCrLf
    s = s & "Guard posts total: " & lay.nPosts & vbCrLf
    s = s & "Deck panels: " & lay.nPanels & vbCrLf
    s = s & "Estimated mass: " & Format$(lay.totalMass, "0") & " kg" & vbCrLf
    s = s & "Estimated cost: GBP " & Format$(lay.totalCost, "0") & vbCrLf & vbCrLf

    If resultPass Then
        s = s & "ACTION: Design may be sent to the SolidWorks model generator."
    Else
        s = s & "ACTION: Reduce span/load, increase material strength, or add larger sections to the workbook."
    End If

    FormatValidationReport = s

End Function



