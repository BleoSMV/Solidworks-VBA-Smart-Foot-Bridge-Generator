Private Function TryPositiveDouble(ByVal rawText As String, ByRef valueOut As Double) As Boolean

    Dim s As String

    TryPositiveDouble = False
    s = Trim$(rawText)
    s = Replace(s, ",", ".")

    If Len(s) = 0 Then Exit Function
    If Not IsNumeric(s) Then Exit Function

    valueOut = CDbl(s)
    If valueOut <= 0# Then Exit Function

    TryPositiveDouble = True

End Function

Private Function ToDouble(ByVal rawValue As Variant) As Double

    Dim s As String

    If IsNumeric(rawValue) Then
        ToDouble = CDbl(rawValue)
        Exit Function
    End If

    s = Trim$(CStr(rawValue))
    s = Replace(s, Chr$(34), "")
    s = Replace(s, "GBP", "", 1, -1, vbTextCompare)
    s = Replace(s, ChrW$(163), "")
    s = Replace(s, "£", "")
    s = Replace(s, " ", "")
    s = Replace(s, ",", ".")

    If Not IsNumeric(s) Then
        Err.Raise 13, "ToDouble", "Cannot convert value to number: " & CStr(rawValue)
    End If

    ToDouble = CDbl(s)

End Function

Private Sub ParseRgbText(ByVal rgbText As String, ByRef rOut As Long, ByRef gOut As Long, ByRef bOut As Long)

    Dim parts() As String

    rgbText = Replace(rgbText, " ", "")
    If Len(rgbText) = 0 Then Exit Sub

    parts = Split(rgbText, ",")

    If UBound(parts) >= 2 Then
        If IsNumeric(parts(0)) And IsNumeric(parts(1)) And IsNumeric(parts(2)) Then
            rOut = ClampByte(CLng(parts(0)))
            gOut = ClampByte(CLng(parts(1)))
            bOut = ClampByte(CLng(parts(2)))
        End If
    End If

End Sub

Private Function ClampByte(ByVal V As Long) As Long

    If V < 0 Then V = 0
    If V > 255 Then V = 255
    ClampByte = V

End Function

Private Function CeilingLong(ByVal valueIn As Double) As Long

    CeilingLong = CLng(Int(valueIn))
    If valueIn > CDbl(CeilingLong) Then CeilingLong = CeilingLong + 1

End Function

Private Function Max6(ByVal a As Double, ByVal b As Double, ByVal c As Double, ByVal d As Double, ByVal e As Double, ByVal f As Double) As Double

    Max6 = a
    If b > Max6 Then Max6 = b
    If c > Max6 Then Max6 = c
    If d > Max6 Then Max6 = d
    If e > Max6 Then Max6 = e
    If f > Max6 Then Max6 = f

End Function


