Private Function FindColumn(ByVal ws As Object, ByVal headerText As String) As Long

    Dim c As Long
    Dim r As Long
    Dim gotText As String
    Dim targetText As String

    targetText = NormaliseHeader(headerText)

    For r = 1 To 10
        For c = 1 To 60
            gotText = NormaliseHeader(CStr(ws.Cells(r, c).Value))
            If gotText = targetText Then
                FindColumn = c
                Exit Function
            End If
        Next c
    Next r

    FindColumn = 0

End Function

Private Function FindHeaderRow(ByVal ws As Object, ByVal requiredHeader As String) As Long

    Dim c As Long
    Dim r As Long
    Dim gotText As String
    Dim targetText As String

    targetText = NormaliseHeader(requiredHeader)

    For r = 1 To 10
        For c = 1 To 60
            gotText = NormaliseHeader(CStr(ws.Cells(r, c).Value))
            If gotText = targetText Then
                FindHeaderRow = r
                Exit Function
            End If
        Next c
    Next r

    FindHeaderRow = 0

End Function

Private Function NormaliseHeader(ByVal s As String) As String

    s = LCase$(Trim$(s))
    s = Replace(s, "²", "2")
    s = Replace(s, "³", "3")
    s = Replace(s, "?", "4")
    s = Replace(s, "£", "gbp")
    s = Replace(s, "€", "eur")
    s = Replace(s, " ", "")
    s = Replace(s, "_", "")
    s = Replace(s, "-", "")
    s = Replace(s, "/", "")
    s = Replace(s, "(", "")
    s = Replace(s, ")", "")

    NormaliseHeader = s

End Function


Private Sub PopulateMaterialFinishCombos()

