Private Function LoadDataWorkbook(ByVal filePath As String, ByVal quiet As Boolean) As Boolean

    Dim p As String
    Dim ext As String
    Dim xlApp As Object
    Dim wb As Object
    Dim wsMaterials As Object
    Dim wsFinishes As Object
    Dim wsSections As Object
    Dim msg As String
    Dim failReason As String

    LoadDataWorkbook = False
    p = NormalizeFilePath(filePath)

    If Not FileExistsSB(p) Then
        If Not quiet Then
            msg = "Workbook was not found:" & vbCrLf
            msg = msg & p & vbCrLf & vbCrLf
            msg = msg & "Check the path in the Data workbook box."
            MsgBox msg, vbExclamation, "SmartBridge workbook not found"
        End If
        Exit Function
    End If

    ext = LCase$(Mid$(p, InStrRev(p, ".") + 1))

    If ext <> "xlsx" And ext <> "xlsm" And ext <> "xls" Then
        If Not quiet Then
            MsgBox "The data file must be an Excel workbook: .xlsx, .xlsm or .xls" & vbCrLf & vbCrLf & _
                   "Path used:" & vbCrLf & p, vbExclamation, "Wrong file type"
        End If
        Exit Function
    End If

    On Error GoTo ReadFail

    Set xlApp = CreateObject("Excel.Application")
    xlApp.DisplayAlerts = False
    xlApp.Visible = False

    Set wb = xlApp.Workbooks.Open(p, False, True)

    Set wsMaterials = GetWorksheetByName(wb, "Materials")
    Set wsFinishes = GetWorksheetByName(wb, "Finishes")
    Set wsSections = GetWorksheetByName(wb, "Sections")

    If wsMaterials Is Nothing Then
        failReason = "Missing worksheet named Materials."
        GoTo ControlledFail
    End If

    If wsFinishes Is Nothing Then
        failReason = "Missing worksheet named Finishes."
        GoTo ControlledFail
    End If

    If wsSections Is Nothing Then
        failReason = "Missing worksheet named Sections."
        GoTo ControlledFail
    End If

    matCount = 0
    finCount = 0
    secCount = 0

    failReason = "Could not read the Materials sheet. Check headers and numeric values."
    ReadMaterialsSheet wsMaterials

    failReason = "Could not read the Finishes sheet. Check headers, multipliers and RGB values."
    ReadFinishesSheet wsFinishes

    failReason = "Could not read the Sections sheet. Check headers and numeric section data."
    ReadSectionsSheet wsSections

    If matCount <= 0 Then
        failReason = "No material rows were loaded from Materials."
        GoTo ControlledFail
    End If

    If finCount <= 0 Then
        failReason = "No finish rows were loaded from Finishes."
        GoTo ControlledFail
    End If

    If secCount <= 0 Then
        failReason = "No section rows were loaded from Sections."
        GoTo ControlledFail
    End If

    wb.Close False
    xlApp.Quit

    Set wsMaterials = Nothing
    Set wsFinishes = Nothing
    Set wsSections = Nothing
    Set wb = Nothing
    Set xlApp = Nothing

    PopulateMaterialFinishCombos
    LoadDataWorkbook = True
    Exit Function

ControlledFail:

    On Error Resume Next
    If Not wb Is Nothing Then wb.Close False
    If Not xlApp Is Nothing Then xlApp.Quit
    Set wsMaterials = Nothing
    Set wsFinishes = Nothing
    Set wsSections = Nothing
    Set wb = Nothing
    Set xlApp = Nothing
    On Error GoTo 0

    LoadBuiltInData

    If Not quiet Then
        msg = "The workbook could not be read." & vbCrLf & vbCrLf
        msg = msg & "Path used:" & vbCrLf
        msg = msg & p & vbCrLf & vbCrLf
        msg = msg & "Reason:" & vbCrLf
        msg = msg & failReason & vbCrLf & vbCrLf
        msg = msg & "Required sheets:" & vbCrLf
        msg = msg & "Materials, Finishes, Sections" & vbCrLf & vbCrLf
        msg = msg & "Built-in data has been reloaded."

        MsgBox msg, vbExclamation, "SmartBridge workbook read error"
    End If

    Exit Function

ReadFail:

    failReason = "VBA/Excel error " & Err.Number & ": " & Err.description
    Resume ControlledFail

End Function

Private Function GetWorksheetByName(ByVal wb As Object, ByVal sheetName As String) As Object

    Dim ws As Object

    For Each ws In wb.Worksheets
        If StrComp(Trim$(CStr(ws.Name)), sheetName, vbTextCompare) = 0 Then
            Set GetWorksheetByName = ws
            Exit Function
        End If
    Next ws

    Set GetWorksheetByName = Nothing

End Function

Private Sub ReadMaterialsSheet(ByVal ws As Object)

    Dim cName As Long
    Dim cE As Long
    Dim cFy As Long
    Dim cDensity As Long
    Dim headerRow As Long
    Dim lastRow As Long
    Dim r As Long
    Dim nameText As String

    cName = FindColumn(ws, "Material Name")
    cE = FindColumn(ws, "E (Pa)")
    cFy = FindColumn(ws, "Fy (Pa)")
    cDensity = FindColumn(ws, "Density (kg/m³)")

    If cDensity = 0 Then cDensity = FindColumn(ws, "Density (kg/m3)")
    If cDensity = 0 Then cDensity = FindColumn(ws, "Density kg/m3")

    headerRow = FindHeaderRow(ws, "Material Name")

    If cName = 0 Or cE = 0 Or cFy = 0 Or cDensity = 0 Or headerRow = 0 Then
        Err.Raise 5, "ReadMaterialsSheet", "Materials sheet headers are missing."
    End If

    lastRow = ws.Cells(ws.Rows.Count, cName).End(-4162).Row

    For r = headerRow + 1 To lastRow
        nameText = Trim$(CStr(ws.Cells(r, cName).Value))

        If Len(nameText) > 0 Then
            AddMaterial nameText, ToDouble(ws.Cells(r, cE).Value), ToDouble(ws.Cells(r, cFy).Value), ToDouble(ws.Cells(r, cDensity).Value)
        End If
    Next r

End Sub

Private Sub ReadFinishesSheet(ByVal ws As Object)

