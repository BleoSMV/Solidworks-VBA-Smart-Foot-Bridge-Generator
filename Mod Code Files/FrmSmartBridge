    If cboMaterial.ListCount > 0 Then
        cboMaterial.ListIndex = 0
        For i = 0 To cboMaterial.ListCount - 1
            If cboMaterial.List(i) = oldMat Then cboMaterial.ListIndex = i
        Next i
